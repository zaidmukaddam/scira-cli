# ── Setup ─────────────────────────────────────────────────────────────────────
# 1. Copy this file to ONE of:
#      ~/.scira/.env            (global — works from any directory)
#      <your-project>/.scira/.env   (project — overrides global in that repo)
# 2. Fill in the keys for your chosen LLM + search providers.
# 3. Run: scira doctor
#
# Or run the interactive wizard: scira init
# Shell env vars always win. Never commit real keys to git.

# ── LLM (pick one provider in config; set its keys) ───────────────────────────

# Default: Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# Dashboard → AI Gateway → API Keys (starts with sk-)
AI_GATEWAY_API_KEY=

# xAI Grok — https://console.x.ai/ → API Keys
XAI_API_KEY=

# Cloudflare Workers AI — https://developers.cloudflare.com/workers-ai/
# Account ID: dash.cloudflare.com overview sidebar
# API token: Profile → API Tokens → "Edit Cloudflare Workers AI" template
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Hugging Face Inference — https://huggingface.co/settings/tokens
HF_API_KEY=

# ── Web search (set the key for search.provider in config) ───────────────────
# Exa — https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Firecrawl — https://www.firecrawl.dev/app/api-keys
# Also used as automatic fallback when Exa/Parallel fail (if set).
FIRECRAWL_API_KEY=

# Parallel — https://platform.parallel.ai/
PARALLEL_API_KEY=
