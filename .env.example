# Copy this file to ~/.scira/.env and fill in your keys.
# Scira loads keys from ~/.scira/.env so they work from any directory
# (including after pnpm link / global install). Never put real keys in
# the project .env — it will not be read by the CLI and risks accidental commits.

# Required: Vercel AI Gateway (all model calls)
AI_GATEWAY_API_KEY=

# Required for Exa search provider
EXA_API_KEY=

# Required for Firecrawl search/scrape provider
FIRECRAWL_API_KEY=

# Required for xAI (Grok) LLM provider
XAI_API_KEY=

# Required for Cloudflare Workers AI LLM provider
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Required for Parallel search provider
PARALLEL_API_KEY=
