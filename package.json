{
  "name": "@scira/cli",
  "version": "0.1.5",
  "description": "Scira — terminal-native AI research agent with grounded sources, verified claims, and local run storage.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "scira": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "research",
    "ai",
    "cli",
    "agent",
    "llm",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaidmukaddam/scira-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zaidmukaddam/scira-cli/issues"
  },
  "homepage": "https://github.com/zaidmukaddam/scira-cli#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run build",
    "dev": "bun src/cli/index.ts",
    "docs:dev": "bun run --cwd docs dev",
    "docs:build": "NODE_ENV=production bun run --cwd docs build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.49",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/xai": "^3.0.95",
    "@clack/prompts": "^1.5.1",
    "@mendable/firecrawl-js": "^4.25.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "ai": "^6.0.203",
    "diff": "^9.0.0",
    "exa-js": "^2.13.0",
    "files-sdk": "^1.8.0",
    "ink": "^7.0.5",
    "ink-link": "^5.0.0",
    "jsdom": "^29.1.1",
    "parallel-web": "^1.1.0",
    "picospinner": "^3.0.0",
    "react": "^19.2.7",
    "react-tweet": "^3.3.1",
    "sade": "^1.8.1",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
